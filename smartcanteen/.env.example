# Browser builds can call the canonical HTTPS FastAPI backend.
VITE_API_BASE_URL=https://smartcanteen.duckdns.org/api

# Local dev uses Vite's /api proxy. Keep this pointed at the local FastAPI server.
VITE_API_PROXY_TARGET=http://127.0.0.1:8000
VITE_API_FALLBACK_BASE_URL=http://127.0.0.1:8000
VITE_API_HOST=127.0.0.1
VITE_API_PORT=8000

# Native app builds need an absolute API URL.
VITE_NATIVE_API_BASE_URL=https://smartcanteen.duckdns.org

# Optional weather integration.
# VITE_OPENWEATHERMAP_API_KEY=
# VITE_OPENWEATHERMAP_LAT=14.5995
# VITE_OPENWEATHERMAP_LON=120.9842
