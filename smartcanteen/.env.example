# Browser builds should call the canonical HTTPS FastAPI backend.
# This keeps custom/static frontend domains from serving index.html for /api.
VITE_API_BASE_URL=https://smartcanteen.duckdns.org/api

# Local dev uses Vite's /api proxy. Change this to http://127.0.0.1:8000
# if you want dev to hit a local FastAPI server instead.
VITE_API_PROXY_TARGET=https://smartcanteen.duckdns.org
VITE_API_FALLBACK_BASE_URL=http://127.0.0.1:8000
VITE_API_HOST=127.0.0.1
VITE_API_PORT=8000

# Native app builds need an absolute API URL.
VITE_NATIVE_API_BASE_URL=https://smartcanteen.duckdns.org

# VITE_OPENWEATHERMAP_API_KEY=
HERMAP_LON=120.9842


VITE_OPENWEATHERMAP_API_KEY=4f4eb2d3e35ff70c1f846f276700ef47
